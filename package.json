{
  "name": "recipe-manager",
  "version": "1.0.0",
  "description": "Recipe Management PWA - Unified SvelteKit Application",
  "type": "module",
  "scripts": {
    "dev": "cd app && npm run dev",
    "build": "cd app && npm run build",
    "preview": "cd app && npm run preview",
    "check": "cd app && npm run check",
    "db:migrate": "cd app && npm run db:migrate",
    "db:generate": "cd app && npm run db:generate",
    "install:all": "cd app && npm install",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  }
}
